# ============================================================
# 跨境电商ERP系统 - 环境变量示例
# 复制此文件为 .env，填入真实值后使用
# 严禁将 .env 提交到 Git！
# ============================================================

# 后端 API 基础地址（开发环境，末尾不要带 /api）
VITE_API_BASE_URL=http://localhost:8000

# Ruitalk AI 客服系统地址（端口 5001）
VITE_RUITALK_URL=http://127.0.0.1:5001

# 应用标题
VITE_APP_TITLE=跨境电商ERP系统

# 1688 开放平台 API Key（如有）
VITE_1688_API_KEY=your_1688_api_key_here

# 其他第三方密钥
# VITE_OTHER_KEY=your_key_here
