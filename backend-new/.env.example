DEBUG=True
DJANGO_SECRET_KEY=replace-me
FERNET_KEY=replace-me-with-fernet-key
DEMO_MODE=true

# 后端对外基地址（供 OpenAPI servers；前端联调用）
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
# 生产拓岳域名示例（文档与 17Track 控制台 Webhook 约定用 tuoyue-tech.com）：
# BACKEND_PUBLIC_URL=https://api.tuoyue-tech.com
# 17Track「小包跟踪推送 URL」填：{BACKEND_PUBLIC_URL}/v1/logistics/webhook
# 例：https://api.tuoyue-tech.com/v1/logistics/webhook
DJANGO_RUNSERVER_PORT=8000

# 17Track：出站请求鉴权（请求头 17token）
TRACK17_API_KEY=C70FBE97D634929414A1565AF717E309
# 物流 Webhook：回调请求头 X-Webhook-Token 须与此一致（强烈建议生产必配）
BACKEND_PUBLIC_URL=https://api.tuoyue-tech.com
LOGISTICS_WEBHOOK_TOKEN=shircici

# RBAC：生产建议 true；联调 false
RBAC_ENFORCE=false
RBAC_API_INTEGRATOR_GROUPS=api_integrator
SMS_PROVIDER=aliyun
SMS_CODE_TTL_SECONDS=300
SMS_SEND_MIN_INTERVAL_SECONDS=60
SMS_VERIFY_MAX_FAILURES=5
SMS_VERIFY_LOCK_SECONDS=900
SMS_SEND_DAILY_LIMIT_PHONE=5
SMS_SEND_IP_MIN_INTERVAL_SECONDS=60
SMS_CAPTCHA_REQUIRED=False
SMS_GLOBAL_HOURLY_LIMIT=10000
DEVICE_PHONE_DAILY_LIMIT=5
SMS_PROVIDER_CHAIN=aliyun,tencent,mock

ALIYUN_ACCESS_KEY_ID=replace_me_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=replace_me_aliyun_access_key_secret
ALIYUN_SMS_SIGN_NAME=replace_me_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=replace_me_sms_template_code
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_REGION=cn-hangzhou

# TikTok OAuth（达人检索）
TIKTOK_CREATOR_APP_KEY=replace_me_tiktok_creator_app_key
TIKTOK_CREATOR_APP_SECRET=replace_me_tiktok_creator_app_secret
TIKTOK_OAUTH_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_CLIENT_KEY=replace_me_tiktok_client_key
TIKTOK_CLIENT_SECRET=replace_me_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://replace_me_api_host:8000/api/auth/tiktok/callback/
TIKTOK_SCOPES=user.info.basic,video.list
TIKTOK_AUTH_BASE_URL=https://www.tiktok.com/v2/auth/authorize/
TIKTOK_API_BASE_URL=https://open.tiktokapis.com/v2/

# MySQL：与本仓库 docker-compose.yml 默认值一致（本机 Django 连 127.0.0.1）
MYSQL_DATABASE=sku_db
MYSQL_USER=backend
MYSQL_PASSWORD=backend_dev_pass
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# 本地无独立只读库时，与主库相同即可
MYSQL_REPLICA_DATABASE=sku_db
MYSQL_REPLICA_USER=backend
MYSQL_REPLICA_PASSWORD=backend_dev_pass
MYSQL_REPLICA_HOST=127.0.0.1
MYSQL_REPLICA_PORT=3306
DB_CONN_MAX_AGE=120
# 演示应急：MySQL 不可达时自动回退 SQLite（避免网关出现全站 502）
DB_FAILOPEN_SQLITE=false
# 演示应急：Redis 不可达时自动回退本地内存缓存（避免中间件触发 500）
CACHE_FAILOPEN_LOCMEM=false

REDIS_URL=redis://127.0.0.1:6379/1
CHANNEL_REDIS_URL=redis://127.0.0.1:6379/2
CORS_ALLOW_ALL_ORIGINS=True
